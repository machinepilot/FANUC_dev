AND  (
LD   %at_reg0.VRS_SETPOINT * Setpoint nominale Y1
EQ   0
)
ST   LvdtLow1      ** Trasduttore LVDT Y1 a zero volt

CAL  T_LVDTAL1(IN=LvdtLow1, PT=%at_reg0.VRS_TIME_SENSORIN) ** Trasduttore LVDT Y1 a zero volt

LD   %at_reg0.VRS_ENAB * Abilitazione regolatore LVDT
EQ   1
AND  T_LVDTAL1.Q   ** Fine tempo allarme trasduttore LVDT Y1
S    %M11.11       ** Mem. allarme trasduttore LVDT Y1

LD   %M5.5         ** Comando stop
R    %M11.11       ** Mem. allarme trasduttore LVDT Y1

LD   %M11.11       ** Mem. allarme trasduttore LVDT Y1
ST   %PLCerr0.11   ** PLCERR Allarme trasduttore LVDT Y1

LD   %C96          ** IN (IW91) Posizione cursore valvola Y2 (0-4095)
LT   %at_reg0.VRS_TH_SENSORIN
AND  (
LD   %at_reg1.VRS_SETPOINT * Setpoint nominale Y2
EQ   0
)
ST   LvdtLow2      ** Trasduttore LVDT Y2 a zero volt

CAL  T_LVDTAL2(IN=LvdtLow2, PT=%at_reg0.VRS_TIME_SENSORIN) ** Trasduttore LVDT Y2 a zero volt

LD   %at_reg1.VRS_ENAB * Abilitazione regolatore LVDT
EQ   1
AND  T_LVDTAL2.Q   ** Fine tempo allarme trasduttore LVDT Y2
S    %M11.12       ** Mem. allarme trasduttore LVDT Y2

LD   %M5.5         ** Comando stop
R    %M11.12       ** Mem. allarme trasduttore LVDT Y2

LD   %M11.12       ** Mem. allarme trasduttore LVDT Y2
ST   %PLCerr0.12   ** PLCERR Allarme trasduttore LVDT Y2

END_FUNCTION_BLOCK




* ------------------------------------------------------------------------
* Gestione piega con sensori d'angolo e loro taratura immediata
* ------------------------------------------------------------------------

FUNCTION_BLOCK GEST_SENSORI

VAR
MemFirstTarget: BOOL; * Mem. primo target richiesto sens. LC
MemEndFirstTarget: BOOL; * Mem. primo target effettuato sens. LC
END_VAR

*-----------------------------
* Gestione sensore angolo LC
*-----------------------------

LD   %C2.7         ** UI-PLC Piega con utilizzo del sensore d'angolo SER/LC
OR   %C2.12        ** UI-PLC Piega con doppio colpo
AND  %dwFlagCOPRA_LC.0 ** PAR-PLC Abilitazione sensore angolo LC-LS
AND  %M13.24       ** Selez. ciclo con misura angolo DATAM-IRIS
ST   %M13.2        ** Piega con sensore DATAM-IRIS

LD   %M13.2        ** Piega con sensore DATAM-IRIS
ANDN %dwFlagCOPRA_LC.2 ** PAR-PLC Abilitazione sensore angolo LS
ST   %C38.3        ** PLC-PP Piega con sensore d'angolo LC

LD   %M13.2        ** Piega con sensore DATAM-IRIS
AND  %dwFlagCOPRA_LC.2 ** PAR-PLC Abilitazione sensore angolo LS
ST   %C38.5        ** PLC-PP Piega con sensore d'angolo LS

LD   %M13.2        ** Piega con sensore DATAM-IRIS
ST   %C38.7        ** PLC-PP Piega con sensore d'angolo LC-LS

LD   %C20.6        ** PP-PLC Posizion. telecamera effettuato
AND  %C35.0        ** PLC-PLC-PP Consensi validi da CH3
ST   %C38.6        ** PLC-PP Conferma telecamere in posizione

LD   %C16.25       ** PP-PLC Richiesta dati da sensore LC (non usato)
S    MemFirstTarget ** Mem. primo target richiesto sens. LC

LDN  %C16.25       ** PP-PLC Richiesta dati da sensore LC (non usato)
AND  MemFirstTarget ** Mem. primo target richiesto sens. LC
S    MemEndFirstTarget ** Mem. primo target effettuato sens. LC

LDN  %M2.10        ** Ciclo di piega in corso
R    MemFirstTarget ** Mem. primo target richiesto sens. LC
R    MemEndFirstTarget ** Mem. primo target effettuato sens. LC

LD   %C16.25       ** PP-PLC Richiesta dati da sensore LC (non usato)
AND  %C38.3        ** PLC-PP Piega con sensore d'angolo LC
ANDN MemEndFirstTarget ** Mem. primo target effettuato sens. LC
ST   %C40.20       ** PLC-UI Rich. primo target a sensore d'angolo LC

LD   %C16.25       ** PP-PLC Richiesta dati da sensore LC (non usato)
AND  %C38.3        ** PLC-PP Piega con sensore d'angolo LC
AND  MemEndFirstTarget ** Mem. primo target effettuato sens. LC
ST   %C40.21       ** PLC-UI Rich. target successivi a sensore d'angolo LC

* Gestione sensori GPS

LD   %GPS          ** PAR-PLC Sensore GPS presente
EQ   1
ST   %C37.6        ** PLC-PP Sensore GPS attivo

* Gestione consensi assi sensore

LD   %cax16.dt26.0 ** PAR-PLC asse S1 in simulato
AND  %M14.16       ** Asse S1 configurato
OR   (
LD   %cax17.dt26.0 ** PAR-PLC asse S2 in simulato
AND  %M14.17       ** Asse S2 configurato
)
ST   %C37.7        ** PLC-PP Sensore in simulato

LD   DP_SENS1      ** UI-PLC Sensore 1 attivo su piega
NE   0
AND  %M14.16       ** Asse S1 configurato
ST   %C37.3        ** PLC-PP Sensore 1 attivo su piega

LD   DP_SENS2      ** UI-PLC Sensore 2 attivo su piega
NE   0
AND  %M14.17       ** Asse S2 configurato
ST   %C37.4        ** PLC-PP Sensore 2 attivo su piega

LD   %C37.3        ** PLC-PP Sensore 1 attivo su piega
OR   %C37.4        ** PLC-PP Sensore 2 attivo su piega
AND  %C37.6        ** PLC-PP Sensore GPS attivo
ST   %M13.1        ** Piega con sensore GPS

* Allarmi sensore

LD   %C21.18       ** PP-PLC Allarme sensore fuori tolleranza al PCL
AND  %C32.0        ** PLC-PLC-PP Consensi validi da CH0
ST   %PLCerr0.18   ** PLCERR Sensore fuori tolleranza

LD   %C21.16       ** PP-PLC Allarme errore angolo
AND  %C32.0        ** PLC-PLC-PP Consensi validi da CH0
OR   %C2.10        ** UI-PLC Calcolo quota piega sens. LC: errore
ST   %PLCerr0.27   ** PLCERR Errore angolo

* Gestione taratura assi sensori GPS

LD   %C60.26       ** IN Taratura sensori GPS
AND  %C37.6        ** PLC-PP Sensore GPS attivo
S    %M13.7        ** Attivazione ciclo taratura sensore GPS

LDN  %M18.16       ** Asse S1 selezionato
ANDN %M18.17       ** Asse S2 selezionato
ANDN %M18.18       ** Asse S3 selezionato
ANDN %M18.19       ** Asse S4 selezionato
ANDN %M18.20       ** Asse S5 selezionato
ANDN %M18.21       ** Asse S6 selezionato
OR   %C18.14       ** PP-PLC Taratura sensori eseguita
OR   %pargene.bgn.7 ** PAR-PLC Pressa tandem sincronizzata
ORN  %M2.2         ** CNC in manuale
OR   %M6.1         ** Emergenza attiva o pulsante STOP
R    %M13.7        ** Attivazione ciclo taratura sensore GPS

* Attivazione taratura sensori selezionati

LD   %M18.16       ** Asse S1 selezionato
ST   %C37.20       ** PLC-PP Asse S1 da tarare

LD   %M18.17       ** Asse S2 selezionato
ST   %C37.21       ** PLC-PP Asse S2 da tarare

LD   %M18.18       ** Asse S3 selezionato
ST   %C37.22       ** PLC-PP Asse S3 da tarare

LD   %M18.19       ** Asse S4 selezionato
ST   %C37.23       ** PLC-PP Asse S4 da tarare

LD   %M18.20       ** Asse S5 selezionato
ST   %C37.24       ** PLC-PP Asse S5 da tarare

LD   %M18.21       ** Asse S6 selezionato
ST   %C37.25       ** PLC-PP Asse S6 da tarare

LD   %C18.14       ** PP-PLC Taratura sensori eseguita
ST   %C37.1        ** PLC-PP Taratura immediata sensori eseguita

END_FUNCTION_BLOCK


*-----------------------------------------------------------------------------
* Gestione consensi con macchina esterna (pressa tandem o robot)
*-----------------------------------------------------------------------------

FUNCTION_BLOCK TANDEM_ROBOT

VAR
PosPestOK: BOOL; * Posizione pestone OK da CN remoto
EnabChkPgmName: BOOL; * Abil. selezione nome programma verso robot
InvalidPgm: BOOL; * Nome programma non valido per robot
EnabReadPgm: BOOL; * Abilita lettura nome programma verso robot
PgmSelected: BOOL; * Programma selezionato correttamente verso robot
ResetInvPgm: BOOL; * Reset messaggio allame nome programma non valido
PgmFromRobot: DWORD; * appoggio numero programma da robot

#defcom TONWAITPGMOK.Q   Fine attesa OK programma da robot
TONWAITPGMOK: TON;
#defcom TONCHKPGM.Q   Fine Tempo controllo programma da robot
TONCHKPGM: TON;
#defcom TOF_PMSREM.Q   IN Macchina remota al PMS OFF Ritardato
TOF_PMSREM: TOF;
END_VAR

