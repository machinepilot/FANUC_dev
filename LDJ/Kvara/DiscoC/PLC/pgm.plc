ST   %PLCerr25
LD   GST1_N26.yErrCode  *Z3
ST   %PLCerr26
LD   GST1_N27.yErrCode  *Z4
ST   %PLCerr27

LD   %cax2.dt1
EQ   8
JMPC ALX1_RING0

