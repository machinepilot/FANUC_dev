*------------------------------------------------------------------------
* Genera segnali per campionamento KLOG
*------------------------------------------------------------------------

FUNCTION LOGGING

* LOG I/O fisici

LD   %C60
ST   %MT0

LD   %C61
ST   %MT1

LD   %C62
ST   %MT2

LD   %C70
ST   %MT3

LD   %C71
ST   %MT4

LD   %C72
ST   %MT5

LD   %C78          ** OUT (QW100) Comando pressione
ST   %RT0

* Limita log bombatura a variazioni significative per non riempire il buffer di dati inutili con bombatura attiva
LD   %C79          ** OUT (QW101) Comando bombatura
SUB  %RT1
ABS
GT   3
JMPCN ELGCR

LD   %C79          ** OUT (QW101) Comando bombatura
ST   %RT1

ELGCR:

* LOG allarmi e messaggi

LD   %PLCerr0
ST   %MT6

LD   %PLCerr1
ST   %MT7

LD   %PLCerr2
ST   %MT8

LD   %PLCmsg0
ST   %MT9

* LOG I/O logici

LD   %C16
ST   %MT10

LD   %C17
ST   %MT11

LD   %C20
SHL  16
OR   %C18
ST   %MT12

LD   %C19
ST   %MT13

LD   %C21
ST   %MT14

LD   %C32
ST   %MT15

LD   %C33
ST   %MT16

LD   %C34
ST   %MT17

LD   %C35
ST   %MT18

LD   %C36
ST   %MT19

LD   %C37
ST   %MT20

LD   %C255
ST   %MT21

LD   %np           ** PP-UI-PLC Numero piega attuale
ST   %RT2

LD   %nrip         ** PP-UI Numero ripetizioni piega attuale
ST   %RT3

LD   %C50          ** PLC-PP Movimentazione richiesta canale 0
ST   %RT4

LD   %C51          ** PLC-PP Movimentazione richiesta canale 1
ST   %RT5

LD   %C52          ** PLC-PP Movimentazione richiesta canale 2
ST   %RT6

LD   %C53          ** PLC-PP Movimentazione richiesta canale 3
ST   %RT7

LD   %C54          ** PLC-PP Movimentazione richiesta canale 4
ST   %RT8

* Logging segnali per sincronismi con slappg.dll

LD   %SLAPPG128    ** Slave-PLC Asse Pestone, Bit usati per diagnostica
AND  16#FFFFFFFC
ST   %MT23

LD   %SLAPPG142
ST   %RT10

LD   %SLAPPG143
ST   %RT11

LD   %SLAPPG144
ST   %RT12

LD   %SLAPPG145
ST   %RT13

END_FUNCTION

*----------------------------------------------------------
*   BLOCCO GESTIONE ERRORI CANOPEN
*----------------------------------------------------------
VAR_IN_OUT
NODE_RESET AT %CanFb59.30;
END_VAR


FUNCTION_BLOCK   ERR_CAN

VAR_INPUT
xType:  BYTE;    * Device type: 0=Axor, 1=Phase, 2=MTS
xConfig:BOOL;    * Config node
xReset: BOOL;    * Reset errors
END_VAR

VAR_OUTPUT
yCnfg:  BOOL;    * Config node
yError: BOOL;    * Node error
yErrCode: DWORD; * Error code
END_VAR

VAR
FBK:    COP_NMT;
R_TSTS: R_TRIG;
BootUp: BOOL;
Err:    WORD;
END_VAR

LD   0
ST   yErrCode      ** Error code

LD   %CanSts0
NE   0
ST   yError        ** Node error

LD   %CanSts0.1
JMPCN  END_EMCY

LD   xType         ** Device type: 0=Axor, 1=Phase, 2=MTS
EQ   0
JMPC T_FATBACK
LD   xType         ** Device type: 0=Axor, 1=Phase, 2=MTS
EQ   1
JMPC T_PHASE
LD   xType         ** Device type: 0=Axor, 1=Phase, 2=MTS
EQ   2
JMPC T_MTS
JMP  END_EMCY

T_FATBACK:
LD   %CanSts4
ST   yErrCode      ** Error code
LD   yErrCode.22    * Flash to eeprom
OR   yErrCode.0
ST   yErrCode.0
LD   yErrCode      ** Error code
AND  16#003FFFFF
ST   yErrCode      ** Error code

* TEST Limiti HW
LD   %CanSts3
EQ   16#FF07      * Nstop
ST   yErrCode.22
LD   %CanSts3
EQ   16#FF08      * Pstop
ST   yErrCode.23
JMP  DS301

T_PHASE:
LD   %CanSts3
SHR  12
ST   Err
LD   %CanSts4
SHL  4
OR   Err
AND  16#00FFFFFF
ST   yErrCode      ** Error code
JMP  DS301

T_MTS:
LD   Err
EQ   5000
ST   yErrCode.0     * Device hardware
LD   Err
EQ   8100
ST   yErrCode.1     * Communication error
LD   Err
EQ   3100
ST   yErrCode.2     * Main voltage
LD   Err
EQ   6300
ST   yErrCode.3     * Data set error
JMP  DS301

DS301:              * Protocollo DS301
LD   %CanSts3
AND  16#FFFF
ST   Err

LD   Err
EQ   16#8110
ST   yErrCode.24    * Can HW overrun
LD   Err
EQ   16#8111
ST   yErrCode.25    * Can SW overrun
LD   Err
EQ   16#8120
ST   yErrCode.26    * Can passive error
LD   Err
EQ   16#8140
ST   yErrCode.27    * Can bus off error
LD   Err
EQ   16#8130
ST   yErrCode.28    * Node guarding error

END_EMCY:
LD   %CanSts0.2
OR   %CanSts0.3
ST   yErrCode.28    * Node guarding error

LD   %CanSts0.5
ST   yErrCode.29    * BootUp error

LD   %CanSts0.6
ST   yErrCode.30    * Device profile error

LD   %CanSts0.0
ST   yErrCode.31    * SDO error

LD   yErrCode.31
AND  xReset        ** Reset errors
OR   NODE_RESET * Reset
ST   NODE_RESET * Reset

LD   xConfig       ** Config node
AND  yErrCode.29
S    yCnfg         ** Config node

CAL  R_TSTS(CLK=yCnfg) ** Config node
LD   R_TSTS.Q
S    BootUp
LD   FBK.CS_CONFIRM
R    BootUp
LD   BootUp
ST   FBK.CM_ENAB
LD   FBK.CS_CONFIRM
ST   FBK.CM_RESET
R    yCnfg         ** Config node
LD   15
ST   FBK.CI_STATE
CAL  FBK

END_FUNCTION_BLOCK


VAR
GST1_N1:  ERR_CAN;
GST1_N2:  ERR_CAN;
GST1_N3:  ERR_CAN;
GST1_N4:  ERR_CAN;
GST1_N5:  ERR_CAN;
GST1_N6:  ERR_CAN;
GST1_N7:  ERR_CAN;
GST1_N8:  ERR_CAN;
GST1_N9:  ERR_CAN;
GST1_N10:  ERR_CAN;
GST1_N11:  ERR_CAN;
GST1_N12:  ERR_CAN;
GST1_N13:  ERR_CAN;
GST1_N14:  ERR_CAN;
GST1_N15:  ERR_CAN;
GST1_N22:  ERR_CAN;
GST1_N23:  ERR_CAN;
GST1_N24:  ERR_CAN;
GST1_N25:  ERR_CAN;
GST1_N26:  ERR_CAN;
GST1_N27:  ERR_CAN;

END_VAR


FUNCTION CAN_ERRORS
* PLCerr7  assegnato ad errori di caricamento dll
* PLCmsg7  assegnato a messaggi della dll
* PLCerr8   = Allarmi nodo 2
* PLCerr9   = Allarmi nodo 3
* PLCerr10  = Allarmi nodo 4
* PLCerr11   = Allarmi nodo 5
* PLCerr12   = Allarmi nodo 6
* PLCerr13   = Allarmi nodo 7
* PLCerr14   = Allarmi nodo 8
* PLCerr15   = Allarmi nodo 9
* PLCerr16   = Allarmi nodo 10
* PLCerr17   = Allarmi nodo 11
* PLCerr18   = Allarmi nodo 12
* PLCerr19   = Allarmi nodo 13
* PLCerr20   = Allarmi nodo 14
* PLCerr21   = Allarmi nodo 15
* PLCerr22   = Allarmi nodo 22
* PLCerr23   = Allarmi nodo 23
* PLCerr24   = Allarmi nodo 24
* PLCerr25   = Allarmi nodo 25
* PLCerr26   = Allarmi nodo 26
* PLCerr27   = Allarmi nodo 27
*--------------------------Rings Alarms
LD   %can_ring0.can_status
AND  16#FFFF
ST   %PLCerr7

LD   %can_ring1.can_status
AND  16#FFFF
SHL  16
OR   %PLCerr7
ST   %PLCerr7

*--------------------------Rings Warnings
LD   %can_ring0.can_status
AND  16#F0000000
SHR  28
ST   %PLCmsg7

LD   %can_ring1.can_status
AND  16#F0000000
SHR  12
OR   %PLCmsg7
ST   %PLCmsg7

LDN  %PLCmsg7.3
AND  %can_ring0.can_enable.0
ST   %PLCmsg7.3

LDN  %PLCmsg7.19
