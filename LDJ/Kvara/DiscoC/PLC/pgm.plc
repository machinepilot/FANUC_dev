I_PEST: GSTPEST;
I_SPEST: SEGNPEST;
I_ANTIWIN: ANTIWDPEST;
I_RISC: GSTRISC;
I_ACCOM: GSTACCOM;
I_AXAUX: GSTAXAUX;
I_AXSENS: GSTAXSENS;
I_RISC34: GSTRISC34;
I_ACCT: GSTACCT;
I_GSTSWLM: GSTSWLM;
I_SEGNEND: SEGNEND;
I_LAZERSAFE: LAZERSAFE;
I_SOGLIEOUTV: SOGLIEOUTV;
I_OUT_GEN: OUT_GEN;
