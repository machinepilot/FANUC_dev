/PROG  PINCH_R01
/ATTR
OWNER		= MNEDITOR;
COMMENT		= "";
PROG_SIZE	= 454;
CREATE		= DATE 25-09-03  TIME 10:31:52;
MODIFIED	= DATE 26-04-20  TIME 12:00:00;
FILE_NAME	= ;
VERSION		= 0;
LINE_COUNT	= 18;
MEMORY_SIZE	= 870;
PROTECT		= READ_WRITE;
STORAGE		= SHADOW;
TCD:  STACK_SIZE	= 0,
      TASK_PRIORITY	= 50,
      TIME_SLICE	= 0,
      BUSY_LAMP_OFF	= 0,
      ABORT_REQUEST	= 0,
      PAUSE_REQUEST	= 0;
DEFAULT_GROUP	= 1,*,*,*,*;
CONTROL_CODE	= 00000000 00000000;
/APPL

AUTO_SINGULARITY_HEADER;
  ENABLE_SINGULARITY_AVOIDANCE   : TRUE;

LINE_TRACK;
  LINE_TRACK_SCHEDULE_NUMBER      : 0;
  LINE_TRACK_BOUNDARY_NUMBER      : 0;
  CONTINUE_TRACK_AT_PROG_END      : TRUE;

/MN
   1:  $WAITTMOUT=3000 ;
   2:  !TODO: confirm DO indices for RESET MUTE/CLAMP ;
   3:  !from Modbus map before enabling these sends. ;
   4:  !DO[40:RESET MUTE]=ON ;
   5:  !DO[41:RESET CLAMP]=ON ;
   6:  IF (DI[25:PRESS AUTO]=OFF),JMP LBL[1] ;
   7:   ;
   8:  WAIT DI[21:BEAM AT UDP]=ON TIMEOUT,LBL[1]    ;
   9:  DO[27:BEAM DOWN CMD]=ON ;
  10:  WAIT DI[22:BEAM AT CP]=ON TIMEOUT,LBL[1]    ;
  11:  DO[22:VACUUM_1]=ON ;
  12:  WAIT R[21:PINCH DWELL] ;
  13:  DO[27:BEAM DOWN CMD]=OFF ;
  14:  JMP LBL[2] ;
  15:  LBL[1] ;
  16:  UALM[5] ;
  17:  PAUSE ;
  18:  LBL[2] ;
/POS
/END
