{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theway.automation/teachpendant/schemas/dataset_entry.schema.json",
  "title": "DatasetEntry",
  "description": "Normalized FANUC knowledge dataset entry frontmatter.",
  "type": "object",
  "required": ["id", "title", "topic", "fanuc_controller", "language", "source", "license", "revision_date"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(FANUC_REF|ONE|EG)_[A-Z0-9_]+$",
      "description": "ID prefix: FANUC_REF_ for reference entries, ONE_ for conceptual articles, EG_ for worked examples."
    },
    "title": { "type": "string", "minLength": 1 },
    "topic": {
      "type": "string",
      "enum": ["motion", "io", "frames", "interrupts", "registers", "pmc", "bg_logic", "dcs", "fieldbus", "vision", "force", "karel", "socket_messaging", "stream_motion", "pc_sdk", "error_codes", "mastering", "offline", "anti_pattern", "safety", "protocols"]
    },
    "fanuc_controller": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["R-30iB", "R-30iB Plus", "R-30iB Mate", "R-30iB Compact Plus", "R-30iA"]
      },
      "minItems": 1
    },
    "system_sw_version": {
      "type": "array",
      "items": { "type": "string" }
    },
    "language": {
      "type": "string",
      "enum": ["TP", "KAREL", "mixed", "na"]
    },
    "source": {
      "type": "object",
      "required": ["type", "title", "tier"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["vendor_manual", "application_note", "training", "error_code_ref", "white_paper", "third_party_integrator", "community", "standards_body", "github_repo", "generated"]
        },
        "title": { "type": "string" },
        "pages": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 0,
          "maxItems": 2
        },
        "tier": {
          "type": "string",
          "enum": ["T1", "T2", "T3", "T4", "generated"]
        },
        "url": { "type": "string" },
        "access_date": { "type": "string" }
      }
    },
    "source_urls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "access_date", "tier"],
        "properties": {
          "url": { "type": "string" },
          "access_date": { "type": "string" },
          "tier": { "type": "string", "enum": ["T1", "T2", "T3", "T4"] },
          "note": { "type": "string" }
        }
      }
    },
    "license": {
      "type": "string",
      "enum": ["reference-only", "public", "cc-by", "cc-by-sa", "proprietary"]
    },
    "revision_date": { "type": "string" },
    "related": {
      "type": "array",
      "items": { "type": "string" }
    },
    "difficulty": {
      "type": "string",
      "enum": ["basic", "intermediate", "advanced"]
    },
    "status": {
      "type": "string",
      "enum": ["approved", "draft", "deprecated"]
    },
    "supersedes": { "type": ["string", "null"] }
  }
}
